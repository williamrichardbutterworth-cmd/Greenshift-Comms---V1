# ───────────────────────── Comms — backend env ─────────────────────────
# Copy this file to ".env" and fill in what you have. Everything works with
# MOCK data out of the box, so you can run the app before adding any keys.

PORT=8080

# ───────────── AI provider (pick one) ─────────────
# The whole app is provider-agnostic. Switch engines by changing this one line.
# Options: claude | openai
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# Update to the latest model string you have access to.
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ───────────── Market data ─────────────
# FALSE = use built-in sample data (no network needed — great for first run).
# TRUE  = attempt live free sources (Elexon + National Gas), falling back to
#         sample data for anything that fails. No API key required for these.
USE_LIVE_MARKET_DATA=false
ELEXON_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1
NATIONAL_GAS_BASE_URL=https://data.nationalgas.com

# Optional free headline price (UK gas, GBp/therm) — OilPriceAPI free tier.
# Leave blank to keep using the sample headline price.
OILPRICE_API_KEY=
OILPRICE_GAS_CODE=NATURAL_GAS_UK

# ───────────── Paid upgrades (leave blank for now) ─────────────
# When approved, drop a key in and flip the matching provider on. See docs.
TRADING_ECONOMICS_KEY=
MONTEL_API_KEY=

# ───────────── News ─────────────
# TRUE = pull live from the curated RSS feed list (free, no key).
# Falls back to sample items if feeds are unreachable.
USE_LIVE_NEWS=true
# Optional paid enrichment (keyword search + sentiment). Blank = RSS only.
MARKETAUX_API_KEY=
NEWSDATA_API_KEY=

# ───────────── Storage: Supabase (production / Vercel) ─────────────
# Persists the Admin Ideas board in Postgres when deployed. Leave BOTH blank
# locally to use the built-in JSON file store instead (zero setup for dev).
# The service-role key is server-side only — never expose it to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
